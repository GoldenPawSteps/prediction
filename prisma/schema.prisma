generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MarketStatus {
  OPEN
  CLOSED
  RESOLVED
  INVALID
  DISPUTED
}

enum MarketType {
  BINARY
  MULTI
}

enum ResolutionOutcome {
  YES
  NO
  INVALID
}

enum TradeType {
  BUY
  SELL
}

enum TradeOutcome {
  YES
  NO
}

enum OrderSide {
  BID
  ASK
}

enum OrderType {
  GTC
  GTD
  FOK
  FAK
}

enum OrderStatus {
  OPEN
  PARTIAL
  FILLED
  CANCELLED
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  username           String    @unique
  passwordHash       String?
  avatar             String?
  bio                String?
  balance            Float     @default(1000.0)
  isAdmin            Boolean   @default(false)
  sessionVersion     Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  trades             Trade[]
  positions          Position[]
  markets            Market[]
  comments           Comment[]
  resolutionVotes    MarketResolutionVote[]
  voteHistory        MarketVoteHistory[]
  disputes           MarketDispute[]
  marketOrders       MarketOrder[]
  makerOrderFills    MarketOrderFill[]     @relation("MarketOrderFillMaker")
  takerOrderFills    MarketOrderFill[]     @relation("MarketOrderFillTaker")
}

model Market {
  id               String           @id @default(cuid())
  title            String
  description      String
  category         String
  marketType       MarketType       @default(BINARY)
  parentMarketId   String?
  outcomeName      String?
  status           MarketStatus     @default(OPEN)
  resolution       ResolutionOutcome?
  resolutionSource String?
  resolutionTime   DateTime?
  endDate          DateTime
  creatorId        String
  creator          User             @relation(fields: [creatorId], references: [id])
  parent           Market?          @relation("MarketChildren", fields: [parentMarketId], references: [id])
  children         Market[]         @relation("MarketChildren")
  yesShares        Float            @default(0)
  noShares         Float            @default(0)
  liquidityParam   Float            @default(100.0)
  totalVolume      Float            @default(0)
  ammVolume        Float            @default(0)
  exchangeVolume   Float            @default(0)
  initialLiquidity Float            @default(100.0)
  disputeWindowHours Int            @default(24)
  tags             String[]         @default([])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  trades           Trade[]
  positions        Position[]
  comments         Comment[]
  priceHistory     PriceHistory[]
  resolutionVotes  MarketResolutionVote[]
  voteHistory      MarketVoteHistory[]
  disputes         MarketDispute[]
  orders           MarketOrder[]
  orderFills       MarketOrderFill[]
}

model Trade {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id])
  marketId   String
  market     Market       @relation(fields: [marketId], references: [id])
  outcome    TradeOutcome
  type       TradeType
  shares     Float
  price      Float
  totalCost  Float
  createdAt  DateTime     @default(now())
}

model Position {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  marketId      String
  market        Market       @relation(fields: [marketId], references: [id])
  outcome       TradeOutcome
  shares        Float        @default(0)
  avgEntryPrice Float        @default(0)
  realizedPnl   Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([userId, marketId, outcome])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id])
  content   String
  createdAt DateTime @default(now())
}

model PriceHistory {
  id        String   @id @default(cuid())
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id])
  yesPrice  Float
  noPrice   Float
  volume    Float    @default(0)
  timestamp DateTime @default(now())
}

model MarketResolutionVote {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  marketId  String
  market    Market           @relation(fields: [marketId], references: [id])
  outcome   ResolutionOutcome
  createdAt DateTime         @default(now())

  @@unique([userId, marketId])
}

/// Immutable log of every vote cast. One row per vote event; a user can have
/// multiple rows (one per time they changed their choice). Use
/// MarketResolutionVote for current-state counting.
model MarketVoteHistory {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id])
  marketId  String
  market    Market            @relation(fields: [marketId], references: [id])
  outcome   ResolutionOutcome
  createdAt DateTime          @default(now())

  @@index([marketId, createdAt])
}

model MarketDispute {
  id               String           @id @default(cuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id])
  marketId         String
  market           Market           @relation(fields: [marketId], references: [id])
  proposedOutcome  ResolutionOutcome
  reason           String
  status           String           @default("OPEN")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model MarketOrder {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id])
  marketId              String
  market                Market      @relation(fields: [marketId], references: [id])
  outcome               TradeOutcome
  side                  OrderSide
  orderType             OrderType   @default(GTC)
  status                OrderStatus @default(OPEN)
  price                 Float
  initialShares         Float
  remainingShares       Float
  reservedAmount        Float       @default(0)
  avgEntryPriceSnapshot Float       @default(0)
  expiresAt             DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  makerFills            MarketOrderFill[] @relation("MarketOrderFillMakerOrder")
  takerFills            MarketOrderFill[] @relation("MarketOrderFillTakerOrder")

  @@index([marketId, outcome, side, status, price, createdAt])
  @@index([userId, marketId, status])
}

model MarketOrderFill {
  id          String       @id @default(cuid())
  marketId    String
  market      Market       @relation(fields: [marketId], references: [id])
  makerOrderId String
  makerOrder   MarketOrder  @relation("MarketOrderFillMakerOrder", fields: [makerOrderId], references: [id])
  takerOrderId String
  takerOrder   MarketOrder  @relation("MarketOrderFillTakerOrder", fields: [takerOrderId], references: [id])
  outcome     TradeOutcome
  price       Float
  shares      Float
  makerUserId String
  makerUser   User         @relation("MarketOrderFillMaker", fields: [makerUserId], references: [id])
  takerUserId String
  takerUser   User         @relation("MarketOrderFillTaker", fields: [takerUserId], references: [id])
  createdAt   DateTime     @default(now())

  @@index([marketId, createdAt])
}
